# syntax=docker/dockerfile:1.7
# Build the naru binary + run the naru-config unit tests (incl. the
# comma-separated app-id matching), reusing the prebuilt base image and the
# cached buildkit mounts from Dockerfile.alloy's release build so this stays
# incremental. The built binary is exported so the comma-list blocks in the
# real config.kdl can be validated with `naru validate`.
#
# apt + rust live in the prebuilt base image (Dockerfile.base) — see there for
# why the package install is factored out of the per-build Dockerfiles.
ARG BASE_IMAGE=naru-build-base:26.04
FROM ${BASE_IMAGE} AS tester
ARG TARGETARCH
WORKDIR /app
COPY . .
RUN --mount=type=cache,id=cargo-registry-${TARGETARCH},target=/usr/local/cargo/registry \
    --mount=type=cache,id=cargo-git-${TARGETARCH},target=/usr/local/cargo/git \
    --mount=type=cache,id=target-naru-${TARGETARCH},target=/app/target,sharing=locked \
    cargo test --release -p naru-config utils::tests -- --nocapture \
    && cargo test --release --lib layout::tests::sim -- --nocapture \
    && cargo build --release --bin naru \
    && install -D /app/target/release/naru /out/naru
